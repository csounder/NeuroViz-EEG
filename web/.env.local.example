# NeuroVis Next.js frontend configuration
# Copy this file to `.env.local` if you need to override defaults.

# Backend HTTP origin (server-enhanced.js) — the Next.js app proxies /api/* to this
NEUROVIS_API_ORIGIN=http://localhost:3000

# Backend WebSocket URL — consumed by the client in the browser
NEXT_PUBLIC_NEUROVIS_WS_URL=ws://localhost:8080
